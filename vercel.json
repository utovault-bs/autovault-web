{
  "rewrites": [
    { "source": "/_/backend/(.*)", "destination": "/_/backend/$1" },
    { "source": "/((?!.*\\..*).*)", "destination": "/index.html" }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "server.js",
      "routePrefix": "/_/backend"
    }
  }
}
